font-family = "GoMono Nerd Font"
unfocused-split-opacity = 0.6 
cursor-style-blink = false 
mouse-hide-while-typing = true 
window-padding-x = 0 
window-padding-y = 0
keybind = super+k=goto_split:up
keybind = super+j=goto_split:down
keybind = super+l=goto_split:right
keybind = super+h=goto_split:left
keybind = super+|=new_split:down
keybind = super+\=new_split:right
keybind = super+left_bracket=previous_tab
keybind = super+right_bracket=next_tab
keybind = super+q=close_surface
keybind = super+w=close_window
window-decoration = none
keybind = super+enter=toggle_split_zoom
keybind = super+t=new_tab
keybind = super+w=close_surface
keybind = super+shift+w=close_window

font-family = "GoMono Nerd Font"
font-family = "Symbols Nerd Font Mono"
font-family = "Noto Sans Symbols 2"
font-family = "Noto Sans Mono"
font-family = "DejaVu Sans Mono"
font-family = "Adwaita Mono"
unfocused-split-opacity = 0.6
cursor-style-blink = false
mouse-hide-while-typing = true
window-padding-x = 0
window-padding-y = 0
keybind = alt+k=goto_split:up
keybind = alt+j=goto_split:down
keybind = alt+l=goto_split:right
keybind = alt+h=goto_split:left
keybind = alt+|=new_split:down
keybind = alt+\=new_split:right
keybind = alt+left_bracket=previous_tab
keybind = alt+right_bracket=next_tab
keybind = alt+enter=toggle_split_zoom
keybind = alt+t=new_tab
keybind = alt+w=close_surface
keybind = alt+shift+w=close_window
window-decoration = server
mouse-scroll-multiplier = 10.0
